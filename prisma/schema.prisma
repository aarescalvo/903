generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Animal {
  id               String            @id
  tropaId          String
  numero           Int
  codigo           String            @unique
  caravana         String?
  tipoAnimal       String
  raza             String?
  pesoVivo         Float?
  estado           String            @default("RECIBIDO")
  corralId         String?
  fechaBaja        DateTime?
  motivoBaja       String?
  pesoBaja         Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  Tropa            Tropa             @relation(fields: [tropaId], references: [id])
  AsignacionGarron AsignacionGarron?
  PesajeIndividual PesajeIndividual?

  @@unique([tropaId, numero])
  @@index([estado])
}

model AsignacionGarron {
  id           String     @id
  listaFaenaId String
  garron       Int
  animalId     String     @unique
  numeroAnimal Int
  horaIngreso  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Animal       Animal     @relation(fields: [animalId], references: [id])
  ListaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id])

  @@unique([listaFaenaId, garron])
  @@index([garron])
}

model Auditoria {
  id           String    @id
  operadorId   String?
  modulo       String
  accion       String
  entidad      String
  entidadId    String?
  descripcion  String
  datosAntes   String?
  datosDespues String?
  fecha        DateTime  @default(now())
  ip           String?
  Operador     Operador? @relation(fields: [operadorId], references: [id])

  @@index([fecha])
  @@index([modulo])
}

model CCIR {
  id                    String    @id
  numeroCertificado     String    @unique
  fechaEmision          DateTime  @default(now())
  producto              String
  cantidad              Float
  lote                  String?
  paisDestino           String
  puertoDestino         String?
  numeroEstablecimiento String?
  nombreEstablecimiento String?
  cuitEstablecimiento   String?
  nombreImportador      String?
  direccionImportador   String?
  numeroContenedor      String?
  matriculaTransporte   String?
  numeroPrecintos       String?
  observaciones         String?
  estado                String    @default("EMITIDO")
  operadorId            String?
  fechaImpresion        DateTime?
  vecesImpreso          Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  Operador              Operador? @relation(fields: [operadorId], references: [id])

  @@index([paisDestino])
  @@index([estado])
  @@index([fechaEmision])
}

model Camara {
  id                                                                String                 @id
  nombre                                                            String                 @unique
  tipo                                                              String                 @default("FAENA")
  capacidad                                                         Int                    @default(0)
  observaciones                                                     String?
  activo                                                            Boolean                @default(true)
  createdAt                                                         DateTime               @default(now())
  updatedAt                                                         DateTime
  MediaRes                                                          MediaRes[]
  MovimientoCamara_MovimientoCamara_camaraDestinoIdToCamara         MovimientoCamara[]     @relation("MovimientoCamara_camaraDestinoIdToCamara")
  MovimientoCamara_MovimientoCamara_camaraOrigenIdToCamara          MovimientoCamara[]     @relation("MovimientoCamara_camaraOrigenIdToCamara")
  MovimientoDespostada_MovimientoDespostada_camaraDestinoIdToCamara MovimientoDespostada[] @relation("MovimientoDespostada_camaraDestinoIdToCamara")
  MovimientoDespostada_MovimientoDespostada_camaraOrigenIdToCamara  MovimientoDespostada[] @relation("MovimientoDespostada_camaraOrigenIdToCamara")
  SesionRomaneo                                                     SesionRomaneo[]
  StockMediaRes                                                     StockMediaRes[]
}

model Cliente {
  id                                  String              @id
  nombre                              String
  cuit                                String?             @unique
  direccion                           String?
  telefono                            String?
  email                               String?
  esProductor                         Boolean             @default(false)
  esUsuarioFaena                      Boolean             @default(false)
  createdAt                           DateTime            @default(now())
  updatedAt                           DateTime
  codigoPostal                        String?
  condicionFiscal                     String?
  contactoAlternativo                 String?
  cuitFacturacion                     String?
  dni                                 String?
  domicilioFacturacion                String?
  inicioActividades                   DateTime?
  localidad                           String?
  numeroMatricula                     String?
  provincia                           String?
  razonSocialFacturacion              String?
  DeclaracionJurada                   DeclaracionJurada[]
  Expedicion                          Expedicion[]
  Factura                             Factura[]
  IngresoDespostada                   IngresoDespostada[]
  PrecioRendering                     PrecioRendering[]
  Rendering                           Rendering[]
  TicketServicio                      TicketServicio[]
  Tropa_Tropa_usuarioFaenaIdToCliente Tropa[]             @relation("Tropa_usuarioFaenaIdToCliente")
  Tropa_Tropa_productorIdToCliente    Tropa[]             @relation("Tropa_productorIdToCliente")
}

model CodigoDestino {
  id        String   @id
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoEspecie {
  id        String   @id
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTipificacion {
  id        String   @id
  codigo    String   @unique
  nombre    String
  especie   String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTipoTrabajo {
  id        String   @id
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CodigoTransporte {
  id        String   @id
  codigo    String   @unique
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model CondicionEmbalaje {
  id                      String                    @id
  nombre                  String                    @unique
  codigo                  String                    @unique
  taraTotal               Float                     @default(0)
  activo                  Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  CondicionEmbalajeInsumo CondicionEmbalajeInsumo[]
  Empaque                 Empaque[]
}

model CondicionEmbalajeInsumo {
  id                  String            @id
  condicionEmbalajeId String
  insumoId            String
  cantidad            Float             @default(1)
  pesoTotal           Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime
  Insumo              Insumo            @relation(fields: [insumoId], references: [id])
  CondicionEmbalaje   CondicionEmbalaje @relation(fields: [condicionEmbalajeId], references: [id], onDelete: Cascade)

  @@unique([condicionEmbalajeId, insumoId])
}

model ConfiguracionFrigorifico {
  id                    String   @id
  nombre                String   @default("Solemar Alimentaria")
  direccion             String?
  numeroEstablecimiento String?
  cuit                  String?
  numeroMatricula       String?
  logo                  String?
  emailHost             String?
  emailPuerto           Int?     @default(587)
  emailUsuario          String?
  emailPassword         String?
  emailHabilitado       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model ConfiguracionRotulo {
  id                   String   @id
  tipo                 String   @unique
  nombre               String
  ancho                Int      @default(100)
  alto                 Int      @default(50)
  campos               String
  incluyeCodigoBarras  Boolean  @default(true)
  codigoBarrasTipo     String   @default("CODE128")
  codigoBarrasPosicion String?
  orientacion          String   @default("HORIZONTAL")
  margenes             String?
  plantilla            String?
  activo               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
}

model ControlCalidad {
  id               String   @id
  fecha            DateTime @default(now())
  tipoControl      String
  camaraId         String?
  proceso          String?
  valor            Float?
  unidad           String?
  valorReferencia  Float?
  dentroDeRango    Boolean  @default(true)
  observaciones    String?
  accionCorrectiva String?
  operadorId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([tipoControl])
  @@index([fecha])
}

model Corral {
  id                                                        String             @id
  nombre                                                    String             @unique
  capacidad                                                 Int                @default(0)
  observaciones                                             String?
  activo                                                    Boolean            @default(true)
  stockBovinos                                              Int                @default(0)
  stockEquinos                                              Int                @default(0)
  createdAt                                                 DateTime           @default(now())
  updatedAt                                                 DateTime
  MovimientoCorral_MovimientoCorral_corralDestinoIdToCorral MovimientoCorral[] @relation("MovimientoCorral_corralDestinoIdToCorral")
  MovimientoCorral_MovimientoCorral_corralOrigenIdToCorral  MovimientoCorral[] @relation("MovimientoCorral_corralOrigenIdToCorral")
  Tropa                                                     Tropa[]
}

model Cuarteo {
  id             String   @id
  mediaResId     String
  codigoMediaRes String
  tropaCodigo    String?
  garron         Int?
  lado           String
  pesoOriginal   Float
  pesoAsado      Float?
  pesoDelantero  Float?
  pesoTrasero    Float?
  pesoTotal      Float?
  perdida        Float?
  camaraId       String?
  operadorId     String?
  fecha          DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@index([tropaCodigo])
  @@index([fecha])
}

model Cuero {
  id             String    @id
  tropaId        String?
  tropaCodigo    String?
  garron         Int?
  peso           Float?
  clasificacion  String    @default("SELECCION")
  observaciones  String?
  enStock        Boolean   @default(true)
  fechaIngreso   DateTime  @default(now())
  fechaSalida    DateTime?
  destino        String?
  precioUnitario Float?
  vendido        Boolean   @default(false)
  operadorId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  @@index([fechaIngreso])
  @@index([enStock])
  @@index([tropaCodigo])
}

model DeclaracionJurada {
  id                 String    @id
  numeroDeclaracion  String    @unique
  fecha              DateTime  @default(now())
  productorId        String?
  nombreProductor    String
  cuitProductor      String?
  direccionProductor String?
  procedencia        String?
  especie            String    @default("BOVINO")
  cantidadCabezas    Int
  numeroTropa        String?
  numeroLote         String?
  numeroDTE          String?
  numeroGuia         String?
  declaracionSanidad String?
  procedenciaLibre   Boolean   @default(true)
  observaciones      String?
  estado             String    @default("ACTIVA")
  operadorId         String?
  fechaImpresion     DateTime?
  vecesImpreso       Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  Operador           Operador? @relation(fields: [operadorId], references: [id])
  Cliente            Cliente?  @relation(fields: [productorId], references: [id])

  @@index([especie])
  @@index([estado])
  @@index([fecha])
}

model DetalleExpedicion {
  id              String     @id
  expedicionId    String
  tipoProducto    String
  descripcion     String
  cantidad        Int        @default(1)
  pesoKg          Float?
  tropaCodigo     String?
  lote            String?
  precioUnitario  Float?
  subtotal        Float?
  stockProductoId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime
  Expedicion      Expedicion @relation(fields: [expedicionId], references: [id], onDelete: Cascade)

  @@index([expedicionId])
}

model DetalleFactura {
  id             String   @id
  facturaId      String
  tipoProducto   String
  descripcion    String
  cantidad       Float    @default(1)
  unidad         String   @default("KG")
  precioUnitario Float    @default(0)
  subtotal       Float    @default(0)
  tropaCodigo    String?
  garron         Int?
  mediaResId     String?
  pesoKg         Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Factura        Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([tipoProducto])
  @@index([facturaId])
}

model Empaque {
  id                  String             @id
  codigo              String             @unique
  productoId          String?
  productoNombre      String
  corteAnatomico      String?
  pesoNeto            Float
  pesoTara            Float              @default(0)
  pesoBruto           Float
  cantidadPiezas      Int                @default(1)
  condicionEmbalajeId String?
  tropaCodigo         String?
  garron              Int?
  fechaFaena          DateTime?
  camaraId            String?
  estado              String             @default("EN_STOCK")
  lote                String?
  operadorId          String?
  fecha               DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime
  CondicionEmbalaje   CondicionEmbalaje? @relation(fields: [condicionEmbalajeId], references: [id])

  @@index([productoNombre])
  @@index([estado])
  @@index([codigo])
}

model Expedicion {
  id                String              @id
  numeroRemito      String              @unique
  clienteId         String
  fecha             DateTime            @default(now())
  fechaDespacho     DateTime?
  transportistaId   String?
  patente           String?
  chofer            String?
  estado            String              @default("PENDIENTE")
  facturaId         String?
  observaciones     String?
  operadorId        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  DetalleExpedicion DetalleExpedicion[]
  Cliente           Cliente             @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
}

model Factura {
  id             String           @id
  numero         String           @unique
  numeroInterno  Int
  clienteId      String
  fecha          DateTime         @default(now())
  fechaEmision   DateTime?
  fechaPago      DateTime?
  subtotal       Float            @default(0)
  iva            Float            @default(0)
  total          Float            @default(0)
  estado         String           @default("PENDIENTE")
  observaciones  String?
  condicionVenta String?
  remito         String?
  operadorId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  DetalleFactura DetalleFactura[]
  Operador       Operador?        @relation(fields: [operadorId], references: [id])
  Cliente        Cliente          @relation(fields: [clienteId], references: [id])

  @@index([fecha])
  @@index([estado])
  @@index([clienteId])
  @@index([numero])
}

model GrasaDressing {
  id            String    @id
  fechaFaena    DateTime  @default(now())
  tropaCodigo   String?
  pesoTotal     Float
  observaciones String?
  enStock       Boolean   @default(true)
  fechaIngreso  DateTime  @default(now())
  fechaSalida   DateTime?
  destino       String?
  precioKg      Float?
  vendido       Boolean   @default(false)
  operadorId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([enStock])
  @@index([fechaFaena])
}

model IngresoDespostada {
  id             String    @id
  fecha          DateTime  @default(now())
  tipoProducto   String
  productoId     String?
  productoNombre String
  tropaCodigo    String?
  fechaFaena     DateTime?
  clienteId      String?
  camaraId       String?
  cantidad       Int       @default(1)
  pesoKg         Float
  medioIngreso   String    @default("SELECCION")
  codigoBarras   String?
  operadorId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  Cliente        Cliente?  @relation(fields: [clienteId], references: [id])

  @@index([tipoProducto])
  @@index([fecha])
}

model Insumo {
  id                      String                    @id
  codigo                  String                    @unique
  nombre                  String
  tipo                    String
  unidad                  String                    @default("KG")
  stockActual             Float                     @default(0)
  stockMinimo             Float                     @default(0)
  pesoUnitario            Float?
  alertaStockBajo         Boolean                   @default(false)
  activo                  Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  CondicionEmbalajeInsumo CondicionEmbalajeInsumo[]
  MovimientoInsumo        MovimientoInsumo[]

  @@index([activo])
  @@index([tipo])
}

model ListaFaena {
  id               String             @id
  fecha            DateTime           @default(now())
  estado           String             @default("ABIERTA")
  cantidadTotal    Int                @default(0)
  supervisorId     String?
  fechaCierre      DateTime?
  observaciones    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  AsignacionGarron AsignacionGarron[]
  Operador         Operador?          @relation(fields: [supervisorId], references: [id])
  ListaFaenaTropa  ListaFaenaTropa[]

  @@index([estado])
  @@index([fecha])
}

model ListaFaenaTropa {
  id           String     @id
  listaFaenaId String
  tropaId      String
  cantidad     Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Tropa        Tropa      @relation(fields: [tropaId], references: [id])
  ListaFaena   ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)

  @@unique([listaFaenaId, tropaId])
}

model MediaRes {
  id        String   @id
  romaneoId String
  lado      String
  peso      Float
  sigla     String   @default("A")
  codigo    String   @unique
  estado    String   @default("EN_CAMARA")
  camaraId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Camara    Camara?  @relation(fields: [camaraId], references: [id])
  Romaneo   Romaneo  @relation(fields: [romaneoId], references: [id])

  @@unique([romaneoId, lado, sigla])
  @@index([estado])
}

model Menudencia {
  id                  String         @id
  tipoMenudenciaId    String
  tropaCodigo         String?
  pesoIngreso         Float?
  pesoElaborado       Float?
  numeroBolsa         Int?
  cantidadBolsas      Int?
  operadorElaboracion String?
  fechaIngreso        DateTime       @default(now())
  fechaElaboracion    DateTime?
  rotuloImpreso       Boolean        @default(false)
  observaciones       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime
  TipoMenudencia      TipoMenudencia @relation(fields: [tipoMenudenciaId], references: [id])

  @@index([fechaIngreso])
  @@index([tropaCodigo])
}

model MovimientoCamara {
  id                                              String    @id
  camaraOrigenId                                  String?
  camaraDestinoId                                 String?
  producto                                        String?
  cantidad                                        Int?
  peso                                            Float?
  tropaCodigo                                     String?
  mediaResId                                      String?
  operadorId                                      String?
  observaciones                                   String?
  fecha                                           DateTime  @default(now())
  createdAt                                       DateTime  @default(now())
  updatedAt                                       DateTime
  Operador                                        Operador? @relation(fields: [operadorId], references: [id])
  Camara_MovimientoCamara_camaraDestinoIdToCamara Camara?   @relation("MovimientoCamara_camaraDestinoIdToCamara", fields: [camaraDestinoId], references: [id])
  Camara_MovimientoCamara_camaraOrigenIdToCamara  Camara?   @relation("MovimientoCamara_camaraOrigenIdToCamara", fields: [camaraOrigenId], references: [id])

  @@index([fecha])
}

model MovimientoCorral {
  id                                              String    @id
  tropaId                                         String?
  animalId                                        String?
  corralOrigenId                                  String?
  corralDestinoId                                 String
  cantidad                                        Int       @default(1)
  especie                                         String?
  observaciones                                   String?
  operadorId                                      String?
  fecha                                           DateTime  @default(now())
  createdAt                                       DateTime  @default(now())
  updatedAt                                       DateTime
  Operador                                        Operador? @relation(fields: [operadorId], references: [id])
  Corral_MovimientoCorral_corralDestinoIdToCorral Corral    @relation("MovimientoCorral_corralDestinoIdToCorral", fields: [corralDestinoId], references: [id])
  Corral_MovimientoCorral_corralOrigenIdToCorral  Corral?   @relation("MovimientoCorral_corralOrigenIdToCorral", fields: [corralOrigenId], references: [id])

  @@index([fecha])
}

model MovimientoDespostada {
  id                                                  String   @id
  tipo                                                String   @default("MOVIMIENTO_ENTRE_CAMARAS")
  camaraOrigenId                                      String?
  camaraDestinoId                                     String?
  productoId                                          String?
  productoNombre                                      String
  tipoProducto                                        String
  cantidad                                            Int      @default(1)
  pesoKg                                              Float
  tropaCodigo                                         String?
  lote                                                String?
  observaciones                                       String?
  operadorId                                          String?
  fecha                                               DateTime @default(now())
  createdAt                                           DateTime @default(now())
  updatedAt                                           DateTime
  Camara_MovimientoDespostada_camaraDestinoIdToCamara Camara?  @relation("MovimientoDespostada_camaraDestinoIdToCamara", fields: [camaraDestinoId], references: [id])
  Camara_MovimientoDespostada_camaraOrigenIdToCamara  Camara?  @relation("MovimientoDespostada_camaraOrigenIdToCamara", fields: [camaraOrigenId], references: [id])

  @@index([tipo])
  @@index([fecha])
}

model MovimientoInsumo {
  id         String   @id
  insumoId   String
  tipo       String
  cantidad   Float
  motivo     String?
  proveedor  String?
  destino    String?
  operadorId String?
  fecha      DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Insumo     Insumo   @relation(fields: [insumoId], references: [id])

  @@index([insumoId])
  @@index([fecha])
}

model Numerador {
  id           String   @id
  nombre       String   @unique
  ultimoNumero Int      @default(0)
  anio         Int?
  updatedAt    DateTime
}

model Operador {
  id                      String              @id
  nombre                  String
  usuario                 String              @unique
  password                String
  pin                     String?
  rol                     String              @default("OPERADOR")
  email                   String?
  activo                  Boolean             @default(true)
  puedePesajeCamiones     Boolean             @default(true)
  puedePesajeIndividual   Boolean             @default(true)
  puedeMovimientoHacienda Boolean             @default(true)
  puedeListaFaena         Boolean             @default(false)
  puedeRomaneo            Boolean             @default(false)
  puedeIngresoCajon       Boolean             @default(false)
  puedeMenudencias        Boolean             @default(false)
  puedeStock              Boolean             @default(false)
  puedeReportes           Boolean             @default(false)
  puedeCCIR               Boolean             @default(false)
  puedeFacturacion        Boolean             @default(false)
  puedeConfiguracion      Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime
  Auditoria               Auditoria[]
  CCIR                    CCIR[]
  DeclaracionJurada       DeclaracionJurada[]
  Factura                 Factura[]
  ListaFaena              ListaFaena[]
  MovimientoCamara        MovimientoCamara[]
  MovimientoCorral        MovimientoCorral[]
  PesajeCamion            PesajeCamion[]
  PesajeIndividual        PesajeIndividual[]
  Romaneo                 Romaneo[]
  SesionRomaneo           SesionRomaneo[]
  Tropa                   Tropa[]
}

model PesajeCamion {
  id              String         @id
  tipo            String         @default("INGRESO_HACIENDA")
  numeroTicket    Int            @unique
  patenteChasis   String
  patenteAcoplado String?
  choferNombre    String?
  choferDni       String?
  transportistaId String?
  destino         String?
  remito          String?
  factura         String?
  precintos       String?
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  observaciones   String?
  estado          String         @default("ABIERTO")
  operadorId      String?
  fecha           DateTime       @default(now())
  fechaTara       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  Operador        Operador?      @relation(fields: [operadorId], references: [id])
  Transportista   Transportista? @relation(fields: [transportistaId], references: [id])
  Tropa           Tropa?

  @@index([fecha])
  @@index([estado])
  @@index([tipo])
}

model PesajeIndividual {
  id            String    @id
  animalId      String    @unique
  peso          Float
  caravana      String?
  observaciones String?
  operadorId    String?
  fecha         DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Operador      Operador? @relation(fields: [operadorId], references: [id])
  Animal        Animal    @relation(fields: [animalId], references: [id])

  @@index([fecha])
}

model PrecioRendering {
  id           String    @id
  clienteId    String
  tipoProducto String
  precioKg     Float
  fechaDesde   DateTime  @default(now())
  fechaHasta   DateTime?
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Cliente      Cliente   @relation(fields: [clienteId], references: [id])

  @@unique([clienteId, tipoProducto, fechaDesde])
  @@index([tipoProducto])
  @@index([clienteId])
}

model Producto {
  id                      String   @id
  codigo                  String
  nombre                  String
  nombreReportes          String?
  especie                 String
  codigoTipificacion      String?
  codigoTipoTrabajo       String?
  codigoTransporte        String?
  codigoDestino           String?
  tara                    Float?
  diasConservacion        Int?
  requiereTipificacion    Boolean  @default(false)
  tipoRotulo              String?
  precio                  Float?
  temperaturaConservacion String?
  apareceRendimiento      Boolean  @default(false)
  apareceStock            Boolean  @default(false)
  activo                  Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime

  @@unique([codigo, especie])
  @@index([especie])
}

model Rendering {
  id            String    @id
  fechaFaena    DateTime  @default(now())
  tropaCodigo   String?
  tipoProducto  String
  pesoKg        Float
  clienteId     String?
  precioKg      Float?
  fechaPrecio   DateTime?
  enStock       Boolean   @default(true)
  fechaIngreso  DateTime  @default(now())
  fechaSalida   DateTime?
  vendido       Boolean   @default(false)
  numeroFactura String?
  observaciones String?
  operadorId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Cliente       Cliente?  @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
  @@index([enStock])
  @@index([tipoProducto])
  @@index([fechaFaena])
}

model Romaneo {
  id                String       @id
  listaFaenaId      String?
  fecha             DateTime     @default(now())
  garron            Int
  tropaCodigo       String?
  numeroAnimal      Int?
  tipoAnimal        String?
  raza              String?
  pesoVivo          Float?
  denticion         String?
  tipificadorId     String?
  pesoMediaIzq      Float?
  pesoMediaDer      Float?
  pesoTotal         Float?
  rinde             Float?
  estado            String       @default("PENDIENTE")
  supervisorId      String?
  fechaConfirmacion DateTime?
  emailEnviado      Boolean      @default(false)
  operadorId        String?
  observaciones     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  MediaRes          MediaRes[]
  Operador          Operador?    @relation(fields: [operadorId], references: [id])
  Tipificador       Tipificador? @relation(fields: [tipificadorId], references: [id])

  @@index([estado])
  @@index([garron])
  @@index([fecha])
}

model SesionRomaneo {
  id            String       @id
  operadorId    String
  tipificadorId String?
  camaraId      String?
  activa        Boolean      @default(true)
  fechaInicio   DateTime     @default(now())
  fechaFin      DateTime?
  ultimoGarron  Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  Camara        Camara?      @relation(fields: [camaraId], references: [id])
  Tipificador   Tipificador? @relation(fields: [tipificadorId], references: [id])
  Operador      Operador     @relation(fields: [operadorId], references: [id])
}

model StockMediaRes {
  id           String   @id
  camaraId     String
  tropaCodigo  String?
  especie      String
  cantidad     Int      @default(0)
  pesoTotal    Float    @default(0)
  fechaIngreso DateTime @default(now())
  updatedAt    DateTime
  Camara       Camara   @relation(fields: [camaraId], references: [id])

  @@unique([camaraId, tropaCodigo, especie])
}

model StockProducto {
  id               String    @id
  productoId       String?
  productoNombre   String
  tipo             String
  camaraId         String?
  cantidad         Int       @default(0)
  pesoKg           Float     @default(0)
  tropaCodigo      String?
  lote             String?
  fechaIngreso     DateTime  @default(now())
  fechaVencimiento DateTime?
  estado           String    @default("DISPONIBLE")
  updatedAt        DateTime

  @@unique([productoNombre, camaraId, lote])
  @@index([estado])
  @@index([tipo])
}

model TicketServicio {
  id               String    @id
  numero           Int       @unique
  tropaId          String    @unique
  fecha            DateTime  @default(now())
  clienteId        String
  cantidadAnimales Int
  pesoTotal        Float?
  precioServicio   Float?
  subtotal         Float     @default(0)
  total            Float     @default(0)
  estado           String    @default("EMITIDO")
  fechaPago        DateTime?
  operadorId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Cliente          Cliente   @relation(fields: [clienteId], references: [id])
  Tropa            Tropa     @relation(fields: [tropaId], references: [id])

  @@index([estado])
  @@index([fecha])
}

model Tipificador {
  id            String          @id
  nombre        String
  apellido      String
  numero        String?
  matricula     String          @unique
  activo        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Romaneo       Romaneo[]
  SesionRomaneo SesionRomaneo[]
}

model TipoMenudencia {
  id            String       @id
  nombre        String       @unique
  activo        Boolean      @default(true)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  Menudencia    Menudencia[]
}

model Transportista {
  id           String         @id
  nombre       String
  cuit         String?        @unique
  direccion    String?
  telefono     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  PesajeCamion PesajeCamion[]
}

model Tropa {
  id                                    String                @id
  numero                                Int                   @unique
  codigo                                String                @unique
  codigoSimplificado                    String?
  productorId                           String?
  usuarioFaenaId                        String
  especie                               String                @default("BOVINO")
  dte                                   String
  guia                                  String
  cantidadCabezas                       Int
  corralId                              String?
  estado                                String                @default("RECIBIDO")
  pesoBruto                             Float?
  pesoTara                              Float?
  pesoNeto                              Float?
  pesoTotalIndividual                   Float?
  observaciones                         String?
  fechaRecepcion                        DateTime              @default(now())
  operadorId                            String?
  pesajeCamionId                        String?               @unique
  createdAt                             DateTime              @default(now())
  updatedAt                             DateTime
  Animal                                Animal[]
  ListaFaenaTropa                       ListaFaenaTropa[]
  TicketServicio                        TicketServicio?
  PesajeCamion                          PesajeCamion?         @relation(fields: [pesajeCamionId], references: [id])
  Operador                              Operador?             @relation(fields: [operadorId], references: [id])
  Corral                                Corral?               @relation(fields: [corralId], references: [id])
  Cliente_Tropa_usuarioFaenaIdToCliente Cliente               @relation("Tropa_usuarioFaenaIdToCliente", fields: [usuarioFaenaId], references: [id])
  Cliente_Tropa_productorIdToCliente    Cliente?              @relation("Tropa_productorIdToCliente", fields: [productorId], references: [id])
  TropaAnimalCantidad                   TropaAnimalCantidad[]

  @@index([fechaRecepcion])
  @@index([estado])
  @@index([especie])
}

model TropaAnimalCantidad {
  id         String   @id
  tropaId    String
  tipoAnimal String
  cantidad   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Tropa      Tropa    @relation(fields: [tropaId], references: [id], onDelete: Cascade)

  @@unique([tropaId, tipoAnimal])
}
