generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== CONFIGURACIÓN FRIGORÍFICO ====================

model ConfiguracionFrigorifico {
  id                      String   @id @default(cuid())
  nombre                  String   @default("Solemar Alimentaria")
  direccion               String?
  numeroEstablecimiento   String?  // N° Establecimiento Oficial
  cuit                    String?
  numeroMatricula         String?  // N° Matrícula
  logo                    String?  // URL del logo (logo.png)
  
  // Configuración de emails
  emailHost               String?  // smtp.office365.com
  emailPuerto             Int?     @default(587)
  emailUsuario            String?  // usuario@solemar.com.ar
  emailPassword           String?  // Encriptado
  emailHabilitado         Boolean  @default(false)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== CORRALES ====================

model Corral {
  id          String   @id @default(cuid())
  nombre      String   @unique
  capacidad   Int      @default(0)
  observaciones String?
  activo      Boolean  @default(true)
  
  // Stock actual
  stockBovinos  Int    @default(0)
  stockEquinos  Int    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movimientosOrigen   MovimientoCorral[]  @relation("CorralOrigen")
  movimientosDestino  MovimientoCorral[]  @relation("CorralDestino")
  tropas              Tropa[]
}

// ==================== CÁMARAS ====================

model Camara {
  id            String        @id @default(cuid())
  nombre        String        @unique
  tipo          TipoCamara    @default(FAENA)
  capacidad     Int           @default(0)  // Ganchos o KG según tipo
  observaciones String?
  activo        Boolean       @default(true)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  movimientosOrigen       MovimientoCamara[]      @relation("CamaraOrigen")
  movimientosDestino      MovimientoCamara[]      @relation("CamaraDestino")
  movimientosDespostOrigen  MovimientoDespostada[] @relation("MovimientoOrigen")
  movimientosDespostDestino MovimientoDespostada[] @relation("MovimientoDestino")
  stockMedias             StockMediaRes[]
  mediasRes               MediaRes[]
  sesionesRomaneo         SesionRomaneo[]
}

enum TipoCamara {
  FAENA      // Capacidad en ganchos
  CUARTEO    // Capacidad en KG
  DEPOSITO   // Capacidad en KG
}

// ==================== TIPIFICADORES ====================

model Tipificador {
  id            String   @id @default(cuid())
  nombre        String
  apellido      String
  numero        String?  // Número interno
  matricula     String   @unique  // Número de matrícula (se usa en rótulos)
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  romaneos      Romaneo[]
  sesionesRomaneo SesionRomaneo[]
}

// ==================== PRODUCTOS ====================

model Producto {
  id                    String          @id @default(cuid())
  codigo                String          // Código de artículo (3 dígitos)
  nombre                String
  nombreReportes        String?
  especie               Especie
  
  // Configuración del código EAN-128 (parte fija)
  codigoTipificacion    String?         // 2 dígitos
  codigoTipoTrabajo     String?         // 1 dígito
  codigoTransporte      String?         // 1 dígito
  codigoDestino         String?         // 2 dígitos
  
  // Datos del producto
  tara                  Float?
  diasConservacion      Int?
  requiereTipificacion  Boolean         @default(false)
  tipoRotulo            TipoRotulo?
  precio                Float?
  temperaturaConservacion String?
  
  // Reportes
  apareceRendimiento    Boolean         @default(false)
  apareceStock          Boolean         @default(false)
  
  activo                Boolean         @default(true)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@unique([codigo, especie])
  @@index([especie])
}

enum TipoRotulo {
  MEDIA_RES
  CUARTO
  MENUDENCIA
  PRODUCTO_TERMINADO_ENVASE_PRIMARIO
  PRODUCTO_TERMINADO_ENVASE_SECUNDARIO
  PRODUCTO_TERMINADO_UN_ENVASE
}

// ==================== TIPOS DE MENUDENCIAS ====================

model TipoMenudencia {
  id            String   @id @default(cuid())
  nombre        String   @unique
  activo        Boolean  @default(true)
  observaciones String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  menudencias   Menudencia[]
}

// ==================== OPERADORES ====================

model Operador {
  id            String   @id @default(cuid())
  nombre        String
  usuario       String   @unique
  password      String   // Hash de la contraseña
  pin           String?  // PIN numérico opcional
  rol           RolOperador @default(OPERADOR)
  email         String?
  activo        Boolean  @default(true)
  
  // Permisos detallados
  puedePesajeCamiones     Boolean @default(true)
  puedePesajeIndividual   Boolean @default(true)
  puedeMovimientoHacienda Boolean @default(true)
  puedeListaFaena         Boolean @default(false)
  puedeRomaneo            Boolean @default(false)
  puedeIngresoCajon       Boolean @default(false)
  puedeMenudencias        Boolean @default(false)
  puedeStock              Boolean @default(false)
  puedeReportes           Boolean @default(false)
  puedeCCIR               Boolean @default(false)
  puedeFacturacion        Boolean @default(false)
  puedeConfiguracion      Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  pesajesCamion        PesajeCamion[]
  pesajesIndividuales  PesajeIndividual[]
  tropasCreadas        Tropa[]
  listasFaena          ListaFaena[]
  romaneos             Romaneo[]
  movimientosCorral    MovimientoCorral[]
  movimientosCamara    MovimientoCamara[]
  auditorias           Auditoria[]
  facturas             Factura[]
  ccirs                CCIR[]
  declaracionesJuradas DeclaracionJurada[]
  sesionesRomaneo      SesionRomaneo[]
}

enum RolOperador {
  OPERADOR
  SUPERVISOR
  ADMINISTRADOR
}

// ==================== CLIENTES / PROVEEDORES ====================

model Cliente {
  id              String   @id @default(cuid())
  nombre          String
  cuit            String?  @unique
  direccion       String?
  telefono        String?
  email           String?
  esProductor     Boolean  @default(false)
  esUsuarioFaena  Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  tropasComoProductor    Tropa[]    @relation("ProductorTropas")
  tropasComoUsuarioFaena Tropa[]    @relation("UsuarioFaenaTropas")
  facturas               Factura[]
  declaracionesJuradas   DeclaracionJurada[]
  expediciones           Expedicion[]
  renderings             Rendering[]
  preciosRendering       PrecioRendering[]
  ticketsServicio        TicketServicio[]
  ingresosDespostada     IngresoDespostada[]
}

// ==================== TRANSPORTISTAS ====================

model Transportista {
  id        String   @id @default(cuid())
  nombre    String
  cuit      String?  @unique
  direccion String?
  telefono  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  pesajes   PesajeCamion[]
}

// ==================== TABLAS DE CÓDIGOS ====================

model CodigoEspecie {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "1", "2", "6", etc.
  nombre      String            // "equino", "bovino", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTransporte {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "BARCO enfriado", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoDestino {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", etc.
  nombre      String            // "Italia", "Francia", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipoTrabajo {
  id          String   @id @default(cuid())
  codigo      String   @unique  // "0", "1", "2", etc.
  nombre      String            // "Ninguna", "descarte", etc.
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodigoTipificacion {
  id          String   @id @default(cuid())
  codigo      String   @unique  // ".00", ".01", ".02", etc.
  nombre      String            // "todas", "M", "A", etc.
  especie     Especie           // Para qué especie aplica
  activo      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== TROPAS ====================

model Tropa {
  id              String      @id @default(cuid())
  numero          Int         @unique
  codigo          String      @unique   // Formato: "B 2026 0001" o "E 2026 0001"
  codigoSimplificado String?            // "B0001" para rótulos
  
  // Origen de los animales
  productorId     String?
  productor       Cliente?    @relation("ProductorTropas", fields: [productorId], references: [id])
  usuarioFaenaId  String
  usuarioFaena    Cliente     @relation("UsuarioFaenaTropas", fields: [usuarioFaenaId], references: [id])
  
  especie         Especie     @default(BOVINO)
  
  // Documentos de tránsito (OBLIGATORIOS)
  dte             String
  guia            String
  
  // Cantidad total
  cantidadCabezas Int
  
  // Tipos de animales (detalle)
  tiposAnimales   TropaAnimalCantidad[]
  
  // Corral asignado
  corralId        String?
  corral          Corral?     @relation(fields: [corralId], references: [id])
  
  // Estado
  estado          EstadoTropa @default(RECIBIDO)
  
  // Pesos (del pesaje de camión)
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Pesaje individual (suma de animales pesados)
  pesoTotalIndividual Float?
  
  observaciones   String?
  fechaRecepcion  DateTime    @default(now())
  
  // Operador que registró
  operadorId      String?
  operador        Operador?   @relation(fields: [operadorId], references: [id])
  
  // Relación con pesaje de camión
  pesajeCamionId  String?     @unique
  pesajeCamion    PesajeCamion?  @relation(fields: [pesajeCamionId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  animales        Animal[]
  listasFaena     ListaFaenaTropa[]
  ticketServicio  TicketServicio?
  
  @@index([especie])
  @@index([estado])
  @@index([fechaRecepcion])
}

// Detalle de tipos de animales por tropa
model TropaAnimalCantidad {
  id          String   @id @default(cuid())
  tropaId     String
  tropa       Tropa    @relation(fields: [tropaId], references: [id], onDelete: Cascade)
  tipoAnimal  TipoAnimal
  cantidad    Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([tropaId, tipoAnimal])
}

enum Especie {
  BOVINO
  EQUINO
}

enum TipoAnimal {
  // Bovinos
  TO    // Toro
  VA    // Vaca
  VQ    // Vaquillona
  MEJ   // Torito/Mej
  NO    // Novillo
  NT    // Novillito
  
  // Equinos
  PADRILLO
  POTRILLO
  YEGUA
  CABALLO
  BURRO
  MULA
}

enum EstadoTropa {
  RECIBIDO
  EN_CORRAL
  EN_PESAJE
  PESADO
  LISTO_FAENA
  EN_FAENA
  FAENADO
  DESPACHADO
}

// ==================== ANIMALES ====================

model Animal {
  id             String       @id @default(cuid())
  tropaId        String
  tropa          Tropa        @relation(fields: [tropaId], references: [id])
  
  numero         Int          // Número secuencial dentro de la tropa
  codigo         String       @unique // Código completo: B20260001-001
  
  // Identificación
  caravana       String?      // Número de caravana/arete
  tipoAnimal     TipoAnimal
  raza           String?      // Raza del animal (Angus, Hereford, etc.)
  
  pesoVivo       Float?       // Peso en pie (del pesaje individual)
  
  estado         EstadoAnimal @default(RECIBIDO)
  corralId       String?      // Corral actual (para movimientos)
  
  // Baja/Fallecimiento
  fechaBaja      DateTime?
  motivoBaja     String?
  pesoBaja       Float?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  pesajeIndividual PesajeIndividual?
  asignacionGarron  AsignacionGarron?
  
  @@unique([tropaId, numero])
  @@index([estado])
}

enum EstadoAnimal {
  RECIBIDO
  PESADO
  EN_FAENA
  FAENADO
  EN_CAMARA
  DESPACHADO
  FALLECIDO
}

// ==================== MOVIMIENTOS DE CORRAL ====================

model MovimientoCorral {
  id            String   @id @default(cuid())
  tropaId       String?
  animalId      String?
  
  corralOrigenId  String?
  corralOrigen    Corral?  @relation("CorralOrigen", fields: [corralOrigenId], references: [id])
  corralDestinoId String
  corralDestino   Corral   @relation("CorralDestino", fields: [corralDestinoId], references: [id])
  
  cantidad      Int      @default(1)
  especie       Especie?
  observaciones String?
  
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== PESAJE CAMIÓN ====================

model PesajeCamion {
  id              String          @id @default(cuid())
  tipo            TipoPesajeCamion @default(INGRESO_HACIENDA)
  numeroTicket    Int             @unique
  
  // Datos del vehículo
  patenteChasis   String
  patenteAcoplado String?
  
  // Chofer
  choferNombre    String?
  choferDni       String?
  
  // Transportista
  transportistaId String?
  transportista   Transportista?  @relation(fields: [transportistaId], references: [id])
  
  // Para Ingreso de Hacienda
  tropa           Tropa?
  
  // Para Salida de Mercadería
  destino         String?
  remito          String?
  factura         String?
  precintos       String?         // Números de precinto separados por coma
  
  // Pesos
  pesoBruto       Float?
  pesoTara        Float?
  pesoNeto        Float?
  
  // Para pesaje particular
  observaciones   String?
  
  // Estado
  estado          EstadoPesaje    @default(ABIERTO)
  
  // Operador
  operadorId      String?
  operador        Operador?       @relation(fields: [operadorId], references: [id])
  
  fecha           DateTime        @default(now())
  fechaTara       DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([tipo])
  @@index([estado])
  @@index([fecha])
}

enum TipoPesajeCamion {
  INGRESO_HACIENDA
  PESAJE_PARTICULAR
  SALIDA_MERCADERIA
}

enum EstadoPesaje {
  ABIERTO
  CERRADO
  ANULADO
}

// ==================== PESAJE INDIVIDUAL ====================

model PesajeIndividual {
  id            String     @id @default(cuid())
  animalId      String     @unique
  animal        Animal     @relation(fields: [animalId], references: [id])
  
  peso          Float
  caravana      String?    // Si se lee automáticamente
  observaciones String?
  
  operadorId    String?
  operador      Operador?  @relation(fields: [operadorId], references: [id])
  
  fecha         DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@index([fecha])
}

// ==================== LISTA DE FAENA ====================

model ListaFaena {
  id            String          @id @default(cuid())
  fecha         DateTime        @default(now())  // Una por día
  estado        EstadoListaFaena @default(ABIERTA)
  
  cantidadTotal Int             @default(0)
  
  supervisorId  String?         // Quien cierra la lista
  supervisor    Operador?       @relation(fields: [supervisorId], references: [id])
  fechaCierre   DateTime?
  
  observaciones String?
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  tropas        ListaFaenaTropa[]
  asignaciones  AsignacionGarron[]
  
  @@index([fecha])
  @@index([estado])
}

model ListaFaenaTropa {
  id            String   @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena @relation(fields: [listaFaenaId], references: [id], onDelete: Cascade)
  
  tropaId       String
  tropa         Tropa    @relation(fields: [tropaId], references: [id])
  
  cantidad      Int      // Cantidad de animales de esta tropa a faenar
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([listaFaenaId, tropaId])
}

enum EstadoListaFaena {
  ABIERTA
  EN_PROCESO
  CERRADA
  ANULADA
}

// ==================== ASIGNACIÓN DE GARRÓN ====================

model AsignacionGarron {
  id            String       @id @default(cuid())
  listaFaenaId  String
  listaFaena    ListaFaena   @relation(fields: [listaFaenaId], references: [id])
  
  garron        Int          // Número de garrón (correlativo por día)
  
  animalId      String       @unique
  animal        Animal       @relation(fields: [animalId], references: [id])
  
  // Datos al momento de la asignación (se pueden modificar)
  numeroAnimal  Int          // Número del animal dentro de la tropa
  
  // Hora de ingreso a faena
  horaIngreso   DateTime     @default(now())
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([listaFaenaId, garron])
  @@index([garron])
}

// ==================== ROMANEO ====================

model Romaneo {
  id                String        @id @default(cuid())
  listaFaenaId      String?
  fecha             DateTime      @default(now())
  
  // Datos del animal
  garron            Int
  tropaCodigo       String?
  numeroAnimal      Int?
  tipoAnimal        TipoAnimal?
  raza              String?
  pesoVivo          Float?        // KG ingreso
  
  // Tipificación
  denticion        String?        // Cantidad de dientes
  tipificadorId    String?
  tipificador      Tipificador?  @relation(fields: [tipificadorId], references: [id])
  
  // Pesos de medias reses
  pesoMediaIzq      Float?
  pesoMediaDer      Float?
  pesoTotal         Float?        // Suma de ambas medias
  
  // Rinde
  rinde             Float?        // Porcentaje
  
  // Estado
  estado            EstadoRomaneo @default(PENDIENTE)
  supervisorId      String?       // Quien confirma
  fechaConfirmacion DateTime?
  emailEnviado      Boolean       @default(false)
  
  operadorId        String?
  operador          Operador?     @relation(fields: [operadorId], references: [id])
  
  observaciones     String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  mediasRes         MediaRes[]
  
  @@index([fecha])
  @@index([garron])
  @@index([estado])
}

enum EstadoRomaneo {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

// ==================== MEDIAS RESES ====================

model MediaRes {
  id            String       @id @default(cuid())
  romaneoId     String
  romaneo       Romaneo      @relation(fields: [romaneoId], references: [id])
  
  lado          LadoMedia    // IZQUIERDA o DERECHA
  peso          Float
  sigla         SiglaMedia   @default(A)  // A, T, D
  
  // Código de barras
  codigo        String       @unique
  
  // Estado
  estado        EstadoMediaRes @default(EN_CAMARA)
  
  // Cámara
  camaraId      String?
  camara        Camara?      @relation(fields: [camaraId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@unique([romaneoId, lado, sigla])
  @@index([estado])
}

enum LadoMedia {
  IZQUIERDA
  DERECHA
}

enum SiglaMedia {
  A   // Asado
  T   // Trasero
  D   // Delantero
}

enum EstadoMediaRes {
  EN_CAMARA
  EN_CUARTEO
  DESPACHADO
}

// ==================== STOCK CÁMARA ====================

model StockMediaRes {
  id            String   @id @default(cuid())
  camaraId      String
  camara        Camara   @relation(fields: [camaraId], references: [id])
  
  tropaCodigo   String?
  especie       Especie
  
  cantidad      Int      @default(0)
  pesoTotal     Float    @default(0)
  
  fechaIngreso  DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([camaraId, tropaCodigo, especie])
}

// ==================== MOVIMIENTOS DE CÁMARA ====================

model MovimientoCamara {
  id              String   @id @default(cuid())
  
  camaraOrigenId  String?
  camaraOrigen    Camara?  @relation("CamaraOrigen", fields: [camaraOrigenId], references: [id])
  camaraDestinoId String?
  camaraDestino   Camara?  @relation("CamaraDestino", fields: [camaraDestinoId], references: [id])
  
  producto        String?  // Qué se movió
  cantidad        Int?
  peso            Float?
  
  // Trazabilidad
  tropaCodigo     String?
  mediaResId      String?
  
  operadorId      String?
  operador        Operador? @relation(fields: [operadorId], references: [id])
  
  observaciones   String?
  fecha           DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([fecha])
}

// ==================== MENUDENCIAS ====================

model Menudencia {
  id                String           @id @default(cuid())
  tipoMenudenciaId  String
  tipoMenudencia    TipoMenudencia   @relation(fields: [tipoMenudenciaId], references: [id])
  
  tropaCodigo       String?
  
  // Pesos
  pesoIngreso       Float?           // KG al ingresar a cámara
  pesoElaborado     Float?           // KG después de elaboración
  
  // Bolsas
  numeroBolsa       Int?
  cantidadBolsas    Int?
  
  // Operadores
  operadorElaboracion String?
  
  fechaIngreso      DateTime         @default(now())
  fechaElaboracion  DateTime?
  
  // Rótulo
  rotuloImpreso     Boolean          @default(false)
  
  observaciones     String?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([tropaCodigo])
  @@index([fechaIngreso])
}

// ==================== AUDITORÍA ====================

model Auditoria {
  id            String   @id @default(cuid())
  operadorId    String?
  operador      Operador? @relation(fields: [operadorId], references: [id])
  
  modulo        String
  accion        String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entidad       String
  entidadId     String?
  descripcion   String
  datosAntes    String?  // JSON
  datosDespues  String?  // JSON
  
  fecha         DateTime @default(now())
  ip            String?
  
  @@index([modulo])
  @@index([fecha])
}

// ==================== NUMERADORES ====================

model Numerador {
  id            String   @id @default(cuid())
  nombre        String   @unique  // "TROPA_BOVINO", "TROPA_EQUINO", "TICKET", etc.
  ultimoNumero  Int      @default(0)
  anio          Int?
  
  updatedAt     DateTime @updatedAt
}

// ==================== CCIR - Certificado de Calidad e Inspección Retirada ====================

model CCIR {
  id                    String        @id @default(cuid())
  numeroCertificado     String        @unique  // Número único del certificado
  fechaEmision          DateTime      @default(now())
  
  // Datos del producto
  producto              String        // Descripción del producto
  cantidad              Float         // Cantidad en KG
  lote                  String?       // Lote/tropa de origen
  
  // Destino
  paisDestino           String        // País de destino de la exportación
  puertoDestino         String?       // Puerto de destino
  
  // Datos del establecimiento
  numeroEstablecimiento String?       // N° de establecimiento habilitado
  nombreEstablecimiento String?       // Nombre del establecimiento
  cuitEstablecimiento   String?       // CUIT del establecimiento
  
  // Datos del importador (opcional)
  nombreImportador      String?
  direccionImportador   String?
  
  // Contenedor/Transporte
  numeroContenedor      String?
  matriculaTransporte   String?
  
  // Precintos
  numeroPrecintos       String?       // Números de precintos separados por coma
  
  // Observaciones
  observaciones         String?
  
  // Estado
  estado                EstadoCCIR    @default(EMITIDO)
  
  // Operador que generó
  operadorId            String?
  operador              Operador?     @relation(fields: [operadorId], references: [id])
  
  // Fechas de impresión
  fechaImpresion        DateTime?
  vecesImpreso          Int           @default(0)
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  @@index([fechaEmision])
  @@index([estado])
  @@index([paisDestino])
}

enum EstadoCCIR {
  EMITIDO
  ANULADO
  EXPORTADO
}

// ==================== DECLARACIÓN JURADA ====================

model DeclaracionJurada {
  id                    String              @id @default(cuid())
  numeroDeclaracion     String              @unique  // Número único de declaración
  fecha                 DateTime            @default(now())
  
  // Datos del productor
  productorId           String?
  productor             Cliente?            @relation(fields: [productorId], references: [id])
  nombreProductor       String              // Nombre del productor (denormalizado)
  cuitProductor         String?             // CUIT del productor
  direccionProductor    String?             // Dirección del productor
  
  // Datos del origen
  procedencia           String?             // Lugar de procedencia de los animales
  
  // Datos de la especie
  especie               Especie             @default(BOVINO)
  
  // Cantidad
  cantidadCabezas       Int                 // Cantidad de animales
  
  // Identificación de tropa/lote
  numeroTropa          String?             // Número de tropa
  numeroLote           String?             // Número de lote
  
  // Documentos de origen
  numeroDTE            String?             // Documento de Tránsito Electrónico
  numeroGuia           String?             // Guía de tránsito
  
  // Declaración de sanidad
  declaracionSanidad   String?             // Texto de la declaración
  procedenciaLibre     Boolean             @default(true)  // Si proviene de zona libre
  
  // Observaciones
  observaciones        String?
  
  // Estado
  estado               EstadoDeclaracionJurada  @default(ACTIVA)
  
  // Operador que generó
  operadorId           String?
  operador             Operador?           @relation(fields: [operadorId], references: [id])
  
  // Fechas de impresión
  fechaImpresion       DateTime?
  vecesImpreso         Int                 @default(0)
  
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  
  @@index([fecha])
  @@index([estado])
  @@index([especie])
}

enum EstadoDeclaracionJurada {
  ACTIVA
  ANULADA
  UTILIZADA
}

// ==================== FACTURACIÓN ====================

model Factura {
  id                String        @id @default(cuid())
  numero            String        @unique  // N° de factura (ej: 0001-00001234)
  numeroInterno     Int                    // Número secuencial interno
  
  // Cliente
  clienteId         String
  cliente           Cliente       @relation(fields: [clienteId], references: [id])
  
  // Fechas
  fecha             DateTime      @default(now())
  fechaEmision      DateTime?     // Cuando se emitió
  fechaPago         DateTime?     // Cuando se pagó
  
  // Totales
  subtotal          Float         @default(0)
  iva               Float         @default(0)
  total             Float         @default(0)
  
  // Estado
  estado            EstadoFactura @default(PENDIENTE)
  
  // Observaciones
  observaciones     String?
  
  // Datos adicionales
  condicionVenta    String?       // Contado, Cuenta Corriente, etc.
  remito            String?       // N° de remito asociado
  
  // Operador
  operadorId        String?
  operador          Operador?     @relation(fields: [operadorId], references: [id])
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  detalles          DetalleFactura[]
  
  @@index([numero])
  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
}

model DetalleFactura {
  id                String        @id @default(cuid())
  facturaId         String
  factura           Factura       @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  
  // Producto facturado
  tipoProducto      TipoProductoFactura  // MEDIA_RES, CUARTO, MENUDENCIA, OTRO
  descripcion       String                // Descripción del producto
  
  // Cantidad y precio
  cantidad          Float         @default(1)
  unidad            String        @default("KG")  // KG, UN
  precioUnitario    Float         @default(0)
  subtotal          Float         @default(0)
  
  // Trazabilidad (opcional)
  tropaCodigo       String?       // Código de tropa
  garron            Int?          // Número de garrón
  mediaResId        String?       // ID de media res
  
  // Datos del animal/producto
  pesoKg            Float?        // Peso en KG
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@index([facturaId])
  @@index([tipoProducto])
}

enum EstadoFactura {
  PENDIENTE         // Creada pero no emitida
  EMITIDA           // Emitida al cliente
  PAGADA            // Pagada por el cliente
  ANULADA           // Anulada
}

enum TipoProductoFactura {
  MEDIA_RES         // Media res completa
  CUARTO_DELANTERO  // Cuarto delantero
  CUARTO_TRASERO    // Cuarto trasero
  MENUDENCIA        // Menudencias
  OTRO              // Otros productos
}

// ==================== CONFIGURACIÓN DE RÓTULOS ====================

model ConfiguracionRotulo {
  id                String              @id @default(cuid())
  tipo              TipoRotuloConfig    @unique
  nombre            String
  
  // Dimensiones en mm
  ancho             Int           @default(100)
  alto              Int           @default(50)
  
  // Configuración de campos a imprimir
  campos            String        // JSON con lista de campos y posiciones
  
  // Configuración de código de barras
  incluyeCodigoBarras Boolean     @default(true)
  codigoBarrasTipo  String        @default("CODE128")  // CODE128, EAN13, QR
  codigoBarrasPosicion String?    // TOP, BOTTOM, LEFT, RIGHT
  
  // Configuración de impresión
  orientacion       String        @default("HORIZONTAL")  // HORIZONTAL, VERTICAL
  margenes          String?       // JSON con margenes {top, right, bottom, left}
  
  // Plantilla de texto
  plantilla         String?       // Plantilla HTML o texto con variables
  
  activo            Boolean       @default(true)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum TipoRotuloConfig {
  ANIMAL_EN_PIE     // Rótulo para animal en pie
  MEDIA_RES         // Rótulo para media res
  PRODUCTO          // Rótulo para producto terminado
  SUBPRODUCTO       // Rótulo para subproducto/menudencia
  CAJA              // Rótulo para caja/empaque
}

// ==================== CUEROS ====================

model Cuero {
  id              String          @id @default(cuid())
  
  // Origen
  tropaId         String?
  tropaCodigo     String?
  garron          Int?            // Número de garrón del animal
  
  // Datos del cuero
  peso            Float?          // Peso en kg (opcional, algunos se cuentan por unidad)
  clasificacion   ClasificacionCuero  @default(SELECCION)
  observaciones   String?
  
  // Stock
  enStock         Boolean         @default(true)
  fechaIngreso    DateTime        @default(now())
  fechaSalida     DateTime?
  
  // Destino/Venta
  destino         String?         // Cliente o destino del cuero
  precioUnitario  Float?
  vendido         Boolean         @default(false)
  
  // Operador
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([tropaCodigo])
  @@index([enStock])
  @@index([fechaIngreso])
}

enum ClasificacionCuero {
  SELECCION       // Primera calidad
  PRIMERA         // Segunda calidad
  SEGUNDA         // Tercera calidad
  DESCARTE        // Para renderizado
}

// ==================== GRASA DRESSING ====================

model GrasaDressing {
  id              String          @id @default(cuid())
  
  // Origen - Por fecha de faena
  fechaFaena      DateTime        @default(now())
  tropaCodigo     String?
  
  // Datos
  pesoTotal       Float           // Peso total en kg
  observaciones   String?
  
  // Stock
  enStock         Boolean         @default(true)
  fechaIngreso    DateTime        @default(now())
  fechaSalida     DateTime?
  
  // Destino/Venta
  destino         String?
  precioKg        Float?
  vendido         Boolean         @default(false)
  
  // Operador
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([fechaFaena])
  @@index([enStock])
}

// ==================== RENDERING ====================

model Rendering {
  id              String          @id @default(cuid())
  
  // Fecha de faena (agrupa varias tropas)
  fechaFaena      DateTime        @default(now())
  tropaCodigo     String?         // Opcional, puede agrupar
  
  // Tipo de producto de rendering
  tipoProducto    TipoRendering
  
  // Peso
  pesoKg          Float           // Peso en kg
  
  // Cliente y precio
  clienteId       String?
  cliente         Cliente?        @relation(fields: [clienteId], references: [id])
  precioKg        Float?          // Precio por kg (historial)
  fechaPrecio     DateTime?       // Fecha del precio
  
  // Stock
  enStock         Boolean         @default(true)
  fechaIngreso    DateTime        @default(now())
  fechaSalida     DateTime?
  
  // Venta
  vendido         Boolean         @default(false)
  numeroFactura   String?
  
  // Observaciones
  observaciones   String?
  
  // Operador
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([fechaFaena])
  @@index([tipoProducto])
  @@index([enStock])
  @@index([clienteId])
}

enum TipoRendering {
  HUESO
  GRASA
  DESPERDICIO
  FONDO_DIGESTOR
  SANGRE_SANCOCHADA
}

// Precios de rendering por cliente
model PrecioRendering {
  id              String          @id @default(cuid())
  
  clienteId       String
  cliente         Cliente         @relation(fields: [clienteId], references: [id])
  
  tipoProducto    TipoRendering
  
  precioKg        Float
  fechaDesde      DateTime        @default(now())
  fechaHasta      DateTime?       // Null si es precio vigente
  activo          Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@unique([clienteId, tipoProducto, fechaDesde])
  @@index([clienteId])
  @@index([tipoProducto])
}

// ==================== CUARTEO ====================

model Cuarteo {
  id              String          @id @default(cuid())
  
  // Origen - Media res
  mediaResId      String
  codigoMediaRes  String          // Código de la media res
  tropaCodigo     String?
  garron          Int?
  lado            String          // IZQUIERDA o DERECHA
  pesoOriginal    Float           // Peso de la media res antes del cuarteo
  
  // Cuartos obtenidos (3 cuartos)
  pesoAsado       Float?          // Kg del cuarto asado
  pesoDelantero   Float?          // Kg del cuarto delantero
  pesoTrasero     Float?          // Kg del cuarto trasero
  pesoTotal       Float?          // Suma de los 3 cuartos
  perdida         Float?          // Diferencia entre original y total (hueso, grasa, etc.)
  
  // Stock
  camaraId        String?
  
  // Operador
  operadorId      String?
  
  fecha           DateTime        @default(now())
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([fecha])
  @@index([tropaCodigo])
}

// ==================== STOCK DE PRODUCTOS ====================

model StockProducto {
  id              String          @id @default(cuid())
  
  // Producto
  productoId      String?
  productoNombre  String
  tipo            TipoProductoStock
  
  // Cámara donde está almacenado
  camaraId        String?
  
  // Cantidad
  cantidad        Int             @default(0)
  pesoKg          Float           @default(0)
  
  // Trazabilidad
  tropaCodigo     String?
  lote            String?
  
  // Fechas
  fechaIngreso    DateTime        @default(now())
  fechaVencimiento DateTime?
  
  // Estado
  estado          EstadoStock     @default(DISPONIBLE)
  
  updatedAt       DateTime        @updatedAt
  
  @@unique([productoNombre, camaraId, lote])
  @@index([tipo])
  @@index([estado])
}

enum TipoProductoStock {
  CUERO
  GRASA_DRESSING
  CUARTO_ASADO
  CUARTO_DELANTERO
  CUARTO_TRASERO
  MENUDENCIA
  OTRO
}

enum EstadoStock {
  DISPONIBLE
  RESERVADO
  VENCIDO
  DESPACHADO
}

// ==================== EXPEDICIÓN ====================

model Expedicion {
  id              String          @id @default(cuid())
  numeroRemito    String          @unique
  
  // Cliente destino
  clienteId       String
  cliente         Cliente         @relation(fields: [clienteId], references: [id])
  
  // Fechas
  fecha           DateTime        @default(now())
  fechaDespacho   DateTime?
  
  // Transporte
  transportistaId String?
  patente         String?
  chofer          String?
  
  // Estado
  estado          EstadoExpedicion @default(PENDIENTE)
  
  // Factura asociada
  facturaId       String?
  
  // Observaciones
  observaciones   String?
  
  // Operador
  operadorId      String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  detalles        DetalleExpedicion[]
  
  @@index([fecha])
  @@index([estado])
  @@index([clienteId])
}

model DetalleExpedicion {
  id              String          @id @default(cuid())
  expedicionId    String
  expedicion      Expedicion      @relation(fields: [expedicionId], references: [id], onDelete: Cascade)
  
  // Producto
  tipoProducto    TipoProductoExpedicion
  descripcion     String
  
  // Cantidad
  cantidad        Int             @default(1)
  pesoKg          Float?
  
  // Trazabilidad
  tropaCodigo     String?
  lote            String?
  
  // Precio (si aplica)
  precioUnitario  Float?
  subtotal        Float?
  
  // Origen del stock
  stockProductoId String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([expedicionId])
}

enum TipoProductoExpedicion {
  CUERO
  GRASA_DRESSING
  CUARTO_ASADO
  CUARTO_DELANTERO
  CUARTO_TRASERO
  MENUDENCIA
  MEDIA_RES
  OTRO
}

enum EstadoExpedicion {
  PENDIENTE
  EN_PREPARACION
  DESPACHADO
  ENTREGADO
  ANULADO
}

// ==================== SESIÓN DE ROMANEO ====================

model SesionRomaneo {
  id                String        @id @default(cuid())
  operadorId        String
  operador          Operador      @relation(fields: [operadorId], references: [id])
  
  // Configuración de sesión
  tipificadorId     String?
  tipificador       Tipificador?  @relation(fields: [tipificadorId], references: [id])
  camaraId          String?
  camara            Camara?       @relation(fields: [camaraId], references: [id])
  
  // Estado
  activa            Boolean       @default(true)
  fechaInicio       DateTime      @default(now())
  fechaFin          DateTime?
  
  // Último garrón procesado
  ultimoGarron      Int?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ==================== INSUMOS ====================

model Insumo {
  id              String        @id @default(cuid())
  codigo          String        @unique
  nombre          String
  tipo            TipoInsumo
  unidad          String        @default("KG")
  
  // Stock
  stockActual     Float         @default(0)
  stockMinimo     Float         @default(0)
  
  // Peso para cálculo de tara
  pesoUnitario    Float?
  
  // Alertas
  alertaStockBajo Boolean       @default(false)
  
  activo          Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([tipo])
  @@index([activo])
  
  movimientos            MovimientoInsumo[]
  condicionesEmbalaje   CondicionEmbalajeInsumo[]
}

enum TipoInsumo {
  BOLSA
  LAMINA
  CAJA
  FAJA
  ROTULO
  OTRO
}

// Movimientos de insumos
model MovimientoInsumo {
  id              String        @id @default(cuid())
  insumoId        String
  insumo          Insumo        @relation(fields: [insumoId], references: [id])
  
  tipo            TipoMovimientoInsumo
  cantidad        Float
  motivo          String?
  
  // Origen/Destino
  proveedor       String?
  destino         String?
  
  operadorId      String?
  
  fecha           DateTime      @default(now())
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([fecha])
  @@index([insumoId])
}

enum TipoMovimientoInsumo {
  INGRESO
  EGRESO
  AJUSTE
}

// ==================== CONDICIÓN DE EMBALAJE ====================

model CondicionEmbalaje {
  id              String        @id @default(cuid())
  nombre          String        @unique
  codigo          String        @unique
  
  // Insumos que componen esta condición
  insumos         CondicionEmbalajeInsumo[]
  
  // Empaques que usan esta condición
  empaques        Empaque[]
  
  // Tara total calculada
  taraTotal       Float         @default(0)
  
  activo          Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CondicionEmbalajeInsumo {
  id                  String            @id @default(cuid())
  condicionEmbalajeId String
  condicionEmbalaje   CondicionEmbalaje @relation(fields: [condicionEmbalajeId], references: [id], onDelete: Cascade)
  
  insumoId            String
  insumo              Insumo            @relation(fields: [insumoId], references: [id])
  
  cantidad            Float             @default(1)
  pesoTotal           Float             @default(0)
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  @@unique([condicionEmbalajeId, insumoId])
}

// ==================== EMPAQUE ====================

model Empaque {
  id                String          @id @default(cuid())
  
  // Código de barras de la caja/empaque
  codigo            String          @unique
  
  // Producto empacado
  productoId        String?
  productoNombre    String
  corteAnatomico    String?         // Bola de lomo, peceto, etc.
  
  // Peso
  pesoNeto          Float           // Peso del producto
  pesoTara          Float           @default(0) // Peso de insumos
  pesoBruto         Float           // Neto + Tara
  
  // Cantidad de piezas
  cantidadPiezas    Int             @default(1)
  
  // Condición de embalaje usada
  condicionEmbalajeId String?
  condicionEmbalaje   CondicionEmbalaje? @relation(fields: [condicionEmbalajeId], references: [id])
  
  // Trazabilidad
  tropaCodigo       String?
  garron            Int?
  fechaFaena        DateTime?
  
  // Cámara
  camaraId          String?
  
  // Estado
  estado            EstadoEmpaque   @default(EN_STOCK)
  
  // Lote
  lote              String?
  
  // Operador
  operadorId        String?
  
  fecha             DateTime        @default(now())
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@index([codigo])
  @@index([estado])
  @@index([productoNombre])
}

enum EstadoEmpaque {
  EN_STOCK
  RESERVADO
  DESPACHADO
}

// ==================== INGRESO A DESPOSTADA ====================

model IngresoDespostada {
  id                String            @id @default(cuid())
  
  // Fecha de ingreso
  fecha             DateTime          @default(now())
  
  // Qué ingresa
  tipoProducto      TipoProductoDespostada
  productoId        String?
  productoNombre    String
  
  // Origen
  tropaCodigo       String?
  fechaFaena        DateTime?
  
  // Cliente (para la relación)
  clienteId         String?
  cliente           Cliente?          @relation(fields: [clienteId], references: [id])
  
  // Cámara destino
  camaraId          String?
  
  // Cantidad y peso
  cantidad          Int               @default(1)
  pesoKg            Float
  
  // Medio de ingreso
  medioIngreso      MedioIngreso      @default(SELECCION)
  codigoBarras      String?           // Si fue por código de barras
  
  // Operador
  operadorId        String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@index([fecha])
  @@index([tipoProducto])
}

enum TipoProductoDespostada {
  CUARTO_ASADO
  CUARTO_DELANTERO
  CUARTO_TRASERO
  MEDIA_RES
}

enum MedioIngreso {
  CODIGO_BARRAS
  SELECCION
}

// ==================== MOVIMIENTOS DE DESPOSTADA ====================

model MovimientoDespostada {
  id                  String      @id @default(cuid())
  
  // Tipo de movimiento
  tipo                TipoMovimientoDespostada  @default(MOVIMIENTO_ENTRE_CAMARAS)
  
  // Origen
  camaraOrigenId      String?
  camaraOrigen        Camara?     @relation("MovimientoOrigen", fields: [camaraOrigenId], references: [id])
  // Destino
  camaraDestinoId     String?
  camaraDestino       Camara?     @relation("MovimientoDestino", fields: [camaraDestinoId], references: [id])
  
  // Producto
  productoId          String?
  productoNombre      String
  tipoProducto        TipoProductoDespostada
  
  // Cantidad y peso
  cantidad            Int         @default(1)
  pesoKg              Float
  
  // Trazabilidad
  tropaCodigo         String?
  lote                String?
  
  // Observaciones
  observaciones       String?
  
  // Operador
  operadorId          String?
  
  fecha               DateTime    @default(now())
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  @@index([fecha])
  @@index([tipo])
}

enum TipoMovimientoDespostada {
  INGRESO_CAMARA
  MOVIMIENTO_ENTRE_CAMARAS
  INGRESO_DESPOSTADA
  VUELTA_A_DESPOSTE
  SALIDA_EXPEDICION
}

// ==================== CONTROL DE CALIDAD / HACCP ====================

model ControlCalidad {
  id                String          @id @default(cuid())
  
  // Fecha y hora
  fecha             DateTime        @default(now())
  
  // Tipo de control
  tipoControl       TipoControl
  
  // Ubicación
  camaraId          String?
  proceso           String?         // Faena, Desposte, Empaque, etc.
  
  // Mediciones
  valor             Float?
  unidad            String?         // °C, pH, etc.
  valorReferencia   Float?
  dentroDeRango     Boolean         @default(true)
  
  // Observaciones
  observaciones     String?
  accionCorrectiva  String?
  
  // Operador
  operadorId        String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@index([fecha])
  @@index([tipoControl])
}

enum TipoControl {
  TEMPERATURA_CAMARA
  TEMPERATURA_PRODUCTO
  PH
  PUNTO_CRITICO
  INSPECCION_VISUAL
  OTRO
}

// ==================== TICKET DE SERVICIO ====================

model TicketServicio {
  id                String          @id @default(cuid())
  numero            Int             @unique
  
  // Tropa relacionada
  tropaId           String          @unique
  tropa             Tropa           @relation(fields: [tropaId], references: [id])
  
  // Fecha
  fecha             DateTime        @default(now())
  
  // Cliente
  clienteId         String
  cliente           Cliente         @relation(fields: [clienteId], references: [id])
  
  // Detalle del servicio
  cantidadAnimales  Int
  pesoTotal         Float?
  precioServicio    Float?
  
  // Totales
  subtotal          Float           @default(0)
  total             Float           @default(0)
  
  // Estado
  estado            EstadoTicket    @default(EMITIDO)
  fechaPago         DateTime?
  
  // Operador
  operadorId        String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  @@index([fecha])
  @@index([estado])
}

enum EstadoTicket {
  EMITIDO
  PAGADO
  ANULADO
}
